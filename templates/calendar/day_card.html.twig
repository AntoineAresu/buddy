{% set yesterday = date|date_modify('-1 day')|date('Y-m-d') %}
{% set yesterdayNight = dog.yesterdayNight %}

<div class="col-md-6 col-lg-4">
    <div class="card border-0 rounded-4 shadow-sm h-100">
        <div class="card-body text-dark d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h4 class="mb-0">{% block title %}{% endblock %}</h4>
                    <p class="mb-0 font-size-secondary">{% block subTitle %}{% endblock %}</p>
                </div>
                <div class="rounded-2 d-flex align-items-center justify-content-center">
                    {% block icon %}{% endblock %}
                </div>
            </div>
            {% block content %}{% endblock %}
            {% block button %}{% endblock %}
        </div>
    </div>
</div>
